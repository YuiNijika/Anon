{
  "name": "anon-theme-note",
  "version": "1.0.0",
  "description": "简洁日志主题",
  "author": "YuiNijika",
  "homepage": "https://github.com/YuiNijika/AnonCMS-Theme-Note",
  "private": true,
  "anon": {
    "displayName": "Note",
    "screenshot": "screenshot.jpg",
    "devMode": {
      "enabled": true,
      "vitePort": 5173
    }
  },
  "scripts": {
    "build": "pnpm run copy:libs && pnpm run build:css && pnpm run build:js",
    "dev": "vite",
    "build:css": "tailwindcss -i ./src/input.css -o ./assets/style.css --minify",
    "build:js": "vite build",
    "copy:libs": "copyfiles -f \"node_modules/prismjs/themes/prism-tomorrow.min.css\" \"node_modules/prismjs/plugins/toolbar/prism-toolbar.css\" \"node_modules/nprogress/nprogress.css\" assets"
  },
  "dependencies": {
    "nprogress": "^0.2.0",
    "prismjs": "^1.29.0",
    "prismjs-components-importer": "^0.2.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "autoprefixer": "^10.5.0",
    "copyfiles": "^2.4.1",
    "daisyui": "^5.5.19",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.8"
  }
}
