{
	"dependencies": {
		"scss": "^0.2.4",
		"typescript": "^5.9.3",
		"vue": "^3.5.32"
	},
	"devDependencies": {
		"esbuild": "^0.19.12",
		"sass": "^1.99.0"
	},
	"scripts": {
		"build:debug": "pnpm run build:debug:css && pnpm run build:debug:js",
		"build:debug:css": "sass dev/debug/debug.scss core/Static/debug.css --style compressed --no-source-map",
		"build:debug:js": "esbuild dev/debug/debug.ts --bundle --format=iife --outfile=core/Static/debug.js --minify",
		"watch:debug": "pnpm run watch:debug:css",
		"watch:debug:css": "sass --watch dev/debug/debug.scss:core/Static/debug.css --no-source-map",
		"watch:debug:js": "esbuild dev/debug/debug.ts --bundle --format=iife --global-name=DebugModules --outfile=core/Static/debug.js --watch",
		"build:install": "pnpm run build:install:css && pnpm run build:install:js",
		"build:install:css": "sass dev/install/install.scss core/Static/install.css --style compressed --no-source-map",
		"build:install:js": "esbuild dev/install/install.ts --bundle --format=iife --outfile=core/Static/install.js --minify",
		"watch:install": "pnpm run watch:install:css && pnpm run watch:install:js",
		"watch:install:css": "sass --watch dev/install/install.scss:core/Static/install.css --no-source-map",
		"watch:install:js": "esbuild dev/install/install.ts --bundle --format=iife --outfile=core/Static/install.js --watch",
		"build:comments": "esbuild dev/comments.ts --bundle --format=iife --outfile=core/Static/comments.js --minify",
		"watch:comments": "esbuild dev/comments.ts --bundle --format=iife --outfile=core/Static/comments.js --watch"
	}
}